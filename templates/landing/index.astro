---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Landing page starter built with Astro and Tailwind CSS"
    />
    <title>Supafast Landing</title>
  </head>
  <body class="min-h-screen bg-gradient-to-b from-slate-950 to-slate-900 text-white">
    <main class="mx-auto flex min-h-screen max-w-4xl flex-col items-center justify-center px-6 py-16 text-center">
      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-sky-400">
        Supafast Template
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-6xl">
        Build your landing page faster
      </h1>
      <p class="mb-10 max-w-2xl text-lg text-slate-300">
        Astro + Tailwind CSS — edit
        <code class="rounded bg-slate-800 px-2 py-1 text-sm">src/pages/index.astro</code>
        to customize this starter.
      </p>
      <a
        href="https://docs.astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg bg-sky-500 px-6 py-3 font-semibold text-white transition hover:bg-sky-400"
      >
        Astro Docs
      </a>
    </main>
  </body>
</html>
